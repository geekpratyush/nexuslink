        <module>nexuslink-plugin-api</module>
        <module>nexuslink-core</module>
        <module>nexuslink-security</module>
        <module>nexuslink-protocol-http</module>
        <module>nexuslink-protocol-ai</module>
        <module>nexuslink-protocol-db</module>
