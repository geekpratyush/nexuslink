    <properties>
        <java.version>21</java.version>
        <maven.compiler.source>21</maven.compiler.source>
        <maven.compiler.target>21</maven.compiler.target>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>

        <!-- JavaFX -->
        <javafx.version>21.0.4</javafx.version>

        <!-- HTTP -->
        <okhttp.version>4.12.0</okhttp.version>

        <!-- Kafka -->
        <kafka.version>3.7.0</kafka.version>

        <!-- Security -->
        <bouncycastle.version>1.78.1</bouncycastle.version>

        <!-- SSH/SFTP -->
        <mina.sshd.version>2.13.2</mina.sshd.version>
        <commons.net.version>3.11.1</commons.net.version>

        <!-- JSON -->
        <jackson.version>2.17.2</jackson.version>

        <commonmark.version>0.22.0</commonmark.version>

        <!-- Cache -->
        <caffeine.version>3.1.8</caffeine.version>

        <!-- SQLite -->
        <sqlite.version>3.46.0.0</sqlite.version>

        <!-- UI -->
        <richtextfx.version>0.11.3</richtextfx.version>
        <controlsfx.version>11.2.1</controlsfx.version>

        <!-- Reactive -->
        <rxjava.version>3.1.9</rxjava.version>

        <!-- JMS -->
        <jakarta.jms.version>3.1.0</jakarta.jms.version>

        <!-- MQTT -->
        <paho.version>1.2.5</paho.version>

        <!-- RabbitMQ (AMQP 0.9.1) -->
        <rabbitmq.version>5.21.0</rabbitmq.version>

        <!-- LDAP / Active Directory (UnboundID SDK; bundles an in-memory directory server for tests) -->
        <unboundid.version>7.0.1</unboundid.version>

        <!-- SNMP (SNMP4J) -->
        <snmp4j.version>3.8.2</snmp4j.version>

        <!-- HikariCP -->
        <hikari.version>5.1.0</hikari.version>

        <!-- Anthropic SDK (for AI agent / LLM testing) -->
        <anthropic.version>2.34.0</anthropic.version>

        <!-- Bundled JDBC drivers (small + permissively licensed). Heavy/licensed
             drivers (Oracle, SQL Server, DB2…) load on demand — see TASKS.md §8.1.1 -->
        <h2.version>2.2.224</h2.version>
        <postgresql.version>42.7.3</postgresql.version>
        <mysql.version>8.4.0</mysql.version>
        <mariadb.version>3.4.0</mariadb.version>

        <!-- MongoDB (own module, Apache-2.0) + Testcontainers for live tests -->
        <mongodb.version>5.1.4</mongodb.version>
        <aws.sdk.version>2.27.21</aws.sdk.version>
        <artemis.version>2.31.2</artemis.version>
        <!-- IBM MQ: the *jakarta* client (not allclient, which is javax.jms) to match jakarta.jms 3.1.0.
             Matches the 10.0.0.0 queue manager in test-env. IBM license, redistributable as a client. -->
        <ibmmq.version>10.0.0.0</ibmmq.version>
        <!-- Solace JCSMP wire API. Solace Software License Agreement. -->
        <solace.version>10.30.1</solace.version>
        <lettuce.version>6.3.2.RELEASE</lettuce.version>
        <azure.storage.version>12.27.0</azure.storage.version>
        <azure.servicebus.version>7.17.5</azure.servicebus.version>
        <gcs.version>2.43.2</gcs.version>
        <!-- Aligned with google-cloud-libraries-bom 26.50.0 (same set as storage 2.43.2 / grpc 1.67.1 / protobuf 3.25.5) -->
        <pubsub.version>1.134.0</pubsub.version>
        <grpc.version>1.67.1</grpc.version>
        <protobuf.version>3.25.5</protobuf.version>
        <testcontainers.version>1.20.4</testcontainers.version>

        <!-- Testing -->
        <junit.version>5.10.3</junit.version>
        <mockito.version>5.12.0</mockito.version>
        <testfx.version>4.0.18</testfx.version>

        <!-- Plugin versions -->
        <maven.compiler.plugin.version>3.13.0</maven.compiler.plugin.version>
        <maven.javafx.plugin.version>0.0.8</maven.javafx.plugin.version>
    </properties>

